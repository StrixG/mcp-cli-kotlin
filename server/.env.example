# Home Assistant MCP server — environment (copy to .env, fill in, never commit real values)

# Host root of your Home Assistant instance (with or without a trailing /api).
HA_BASE_URL=http://homeassistant.local:8123

# Long-Lived Access Token: HA -> click your profile -> Security -> Long-Lived Access Tokens -> Create.
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_me

# --- Day 18: background collector / scheduler ---------------------------------

# How often the server polls HA and persists a snapshot. Forms: 60s, 5m, 1h.
# For a demo use a SHORT interval so the scheduler visibly fires (e.g. 60s).
COLLECT_INTERVAL=60s

# Comma-separated entity ids to track. Leave empty to snapshot every entity.
# These are usually numeric sensors (temperature / humidity / energy).
TRACKED_ENTITIES=sensor.outdoor_temperature,sensor.living_room_humidity

# SQLite file for stored measurements. Survives restarts. Default: <server>/data/measurements.db
# DB_PATH=data/measurements.db

# Optional: delete measurements older than this many days each cycle (omit = keep forever).
RETENTION_DAYS=7
