# Home Assistant MCP server — environment (copy to .env, fill in, never commit real values)

# Host root of your Home Assistant instance (with or without a trailing /api).
HA_BASE_URL=http://homeassistant.local:8123

# Long-Lived Access Token: HA -> click your profile -> Security -> Long-Lived Access Tokens -> Create.
HA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_me

# --- Day 18: background collector / scheduler ---------------------------------

# How often the server polls HA and persists a snapshot. Forms: 60s, 5m, 1h.
# For a demo use a SHORT interval so the scheduler visibly fires (e.g. 60s).
COLLECT_INTERVAL=60s

# Comma-separated entity ids to track. Leave empty to snapshot every entity.
# These are usually numeric sensors (temperature / humidity / energy).
TRACKED_ENTITIES=sensor.outdoor_temperature,sensor.living_room_humidity

# SQLite file for stored measurements. Survives restarts. Default: <server>/data/measurements.db
# DB_PATH=data/measurements.db

# Optional: delete measurements older than this many days each cycle (omit = keep forever).
RETENTION_DAYS=7

# --- Day 19: save_report tool -------------------------------------------------

# Directory the save_report tool writes report files into. Created if missing.
# Default: <server>/reports
# OUTPUT_DIR=reports

# --- Day 20: OAuth 2.1 authorization (HTTP/SSE transport only) ----------------
# Protects the server when published to the cloud. stdio runs unauthenticated.

# Turn auth on (default) or off. Only set false for local/dev behind no network.
AUTH_ENABLED=true

# Canonical public URL of this server: JWT issuer + token audience + metadata base.
# REQUIRED when AUTH_ENABLED. No trailing slash. Use the real https:// URL in prod
# (OAuth endpoints + redirect URIs must be HTTPS; terminate TLS at a reverse proxy).
PUBLIC_URL=https://mcp.example.com

# Seeded confidential client for the headless client_credentials grant (the CLI agent).
OAUTH_CLIENT_ID=ha-mcp-cli
OAUTH_CLIENT_SECRET=replace_me_with_a_long_random_secret

# Single-owner password gating the browser login of the authorization_code flow.
OWNER_PASSWORD=replace_me

# Access-token lifetime. Forms: 3600, 90s, 30m, 1h. Default 1h.
# ACCESS_TOKEN_TTL=1h

# Where the RSA signing key is stored. Keep on a durable volume so issued tokens
# survive restarts. Default: <server>/data/oauth-signing-key.json (Docker: /data/...).
# JWT_KEY_PATH=data/oauth-signing-key.json
