# DeepSeek agent — environment (copy to client/.env, fill in, never commit real values).
# Get a key at https://platform.deepseek.com/ -> API keys.
DEEPSEEK_API_KEY=sk-replace_me

# Optional model override. Default is deepseek-v4-pro.
# DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: override which MCP servers the client connects to. Either a path to a
# JSON file, or inline JSON. When unset, the client reads client/servers.json.
# MCP_SERVERS=./servers.json
# MCP_SERVERS=[{"name":"time","command":"npx","args":["-y","time-mcp"]}]

# --- OAuth for the cloud-published Home Assistant MCP server -------------------
# Referenced as ${HA_MCP_CLIENT_ID} / ${HA_MCP_CLIENT_SECRET} from servers.json so
# the secret never lives in that file. Must match OAUTH_CLIENT_ID/OAUTH_CLIENT_SECRET
# on the server. Only needed for the client_credentials flow.
# HA_MCP_CLIENT_ID=ha-mcp-cli
# HA_MCP_CLIENT_SECRET=the_same_long_random_secret_as_the_server
